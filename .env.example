# ── Playto Payout Engine — Environment Variables ────────────────────────────
# Copy this file to .env and fill in your values before running docker compose.
#   cp .env.example .env
#
# Variables marked [REQUIRED in production] will cause a hard startup crash if
# missing when DJANGO_SETTINGS_MODULE=config.settings.production.

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=playto
POSTGRES_USER=playto
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Django ───────────────────────────────────────────────────────────────────
# Use config.settings.local for docker compose dev; config.settings.production on Render.
DJANGO_SETTINGS_MODULE=config.settings.local

# [REQUIRED in production] A long random string used to sign JWTs and cookies.
# Generate with: python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=CHANGE_ME_USE_A_LONG_RANDOM_STRING

# [REQUIRED in production] The public hostname of the deployed API server,
# e.g. myapp.onrender.com — must NOT include https:// or trailing slash.
# Omitting this variable will cause a hard crash on startup in production.
RENDER_EXTERNAL_HOSTNAME=

# [REQUIRED in production] Comma-separated list of allowed CORS origins for the
# frontend, e.g. https://myfrontend.onrender.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Celery ───────────────────────────────────────────────────────────────────
# These are derived from REDIS_URL in docker compose but must be set explicitly
# in production environments that use a managed Redis service.
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
